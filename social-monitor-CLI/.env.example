# social-monitor 环境变量模板（复制为 .env 后填写）

# Mock 模式（与 --demo 等价）
SOCIAL_MONITOR_MOCK_MODE=false

# 平台 Cookie（也可写入 ~/.social-monitor/cookies/）
SM_WEIBO_COOKIE=
SM_XIAOHONGSHU_COOKIE=
SM_DOUYIN_COOKIE=
SM_ZHIHU_COOKIE=

# RSSHub 地址
SOCIAL_MONITOR_RSSHUB_URL=http://localhost:1200

# 飞书通知
SOCIAL_MONITOR_FEISHU_WEBHOOK=

# 存储（postgres 时）
SOCIAL_MONITOR_POSTGRES_HOST=localhost
SOCIAL_MONITOR_POSTGRES_PORT=5432
SOCIAL_MONITOR_POSTGRES_USER=postgres
SOCIAL_MONITOR_POSTGRES_PASSWORD=
SOCIAL_MONITOR_POSTGRES_DATABASE=social_monitor
