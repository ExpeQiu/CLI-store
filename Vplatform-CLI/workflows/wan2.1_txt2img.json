{
  "name": "Wan 2.1 文生图",
  "version": "1.0",
  "profile": "mac_mvp",
  "description": "复用 Wan 2.1 T2V 权重，length=1 输出单帧图片",
  "models": {
    "diffusion": "wan2.1_t2v_1.3B_fp16.safetensors",
    "clip": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
    "vae": "wan_2.1_vae.safetensors"
  },
  "defaults": {
    "positive_prompt": "A fresh red apple on white background, studio lighting, product photography, sharp focus",
    "negative_prompt": "blurry, low quality, distorted, watermark, text, artifacts",
    "width": 832,
    "height": 480,
    "length": 1,
    "steps": 15,
    "cfg": 6.0,
    "sampler_name": "uni_pc",
    "scheduler": "simple",
    "seed": -1
  },
  "required_nodes": [
    "UNETLoader",
    "CLIPLoader",
    "VAELoader",
    "CLIPTextEncode",
    "EmptyHunyuanLatentVideo",
    "KSampler",
    "VAEDecode",
    "SaveImage"
  ],
  "inject": {
    "positive_prompt": ["6", "inputs", "text"],
    "negative_prompt": ["7", "inputs", "text"],
    "width": ["8", "inputs", "width"],
    "height": ["8", "inputs", "height"],
    "length": ["8", "inputs", "length"],
    "seed": ["9", "inputs", "seed"],
    "steps": ["9", "inputs", "steps"],
    "cfg": ["9", "inputs", "cfg"],
    "sampler_name": ["9", "inputs", "sampler_name"],
    "scheduler": ["9", "inputs", "scheduler"]
  },
  "output_nodes": ["11"],
  "prompt": {
    "3": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "wan2.1_t2v_1.3B_fp16.safetensors",
        "weight_dtype": "default"
      }
    },
    "4": {
      "class_type": "CLIPLoader",
      "inputs": {
        "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
        "type": "wan"
      }
    },
    "5": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "wan_2.1_vae.safetensors"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "A fresh red apple on white background, studio lighting, product photography, sharp focus",
        "clip": ["4", 0]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, low quality, distorted, watermark, text, artifacts",
        "clip": ["4", 0]
      }
    },
    "8": {
      "class_type": "EmptyHunyuanLatentVideo",
      "inputs": {
        "width": 832,
        "height": 480,
        "length": 1,
        "batch_size": 1
      }
    },
    "9": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 15,
        "cfg": 6.0,
        "sampler_name": "uni_pc",
        "scheduler": "simple",
        "denoise": 1.0,
        "model": ["3", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["8", 0]
      }
    },
    "10": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["9", 0],
        "vae": ["5", 0]
      }
    },
    "11": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["10", 0],
        "filename_prefix": "vplatform_wan_t2i"
      }
    }
  }
}
