{
  "name": "FLUX.1-dev 文生图",
  "version": "1.0",
  "category": "image",
  "capability": "t2i",
  "source": "local",
  "profile": "keyframe",
  "description": "高质量关键帧生成，需本地部署 FLUX 模型",
  "models": {
    "flux": "flux1-dev-fp8.safetensors",
    "clip": "clip_l.safetensors",
    "vae": "ae.safetensors"
  },
  "defaults": {
    "positive_prompt": "Cinematic product shot, studio lighting, 8k, sharp focus",
    "negative_prompt": "blurry, low quality, distorted, watermark, text",
    "width": 1024,
    "height": 576,
    "steps": 25,
    "cfg": 3.5,
    "sampler_name": "euler",
    "scheduler": "normal",
    "seed": -1
  },
  "required_nodes": [
    "UNETLoader",
    "DualCLIPLoader",
    "VAELoader",
    "CLIPTextEncode",
    "EmptyLatentImage",
    "KSampler",
    "VAEDecode",
    "SaveImage"
  ],
  "inject": {
    "positive_prompt": ["6", "inputs", "text"],
    "negative_prompt": ["7", "inputs", "text"],
    "width": ["8", "inputs", "width"],
    "height": ["8", "inputs", "height"],
    "seed": ["9", "inputs", "seed"],
    "steps": ["9", "inputs", "steps"],
    "cfg": ["9", "inputs", "cfg"],
    "sampler_name": ["9", "inputs", "sampler_name"],
    "scheduler": ["9", "inputs", "scheduler"]
  },
  "output_nodes": ["11"],
  "prompt": {
    "3": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "flux1-dev-fp8.safetensors",
        "weight_dtype": "default"
      }
    },
    "4": {
      "class_type": "DualCLIPLoader",
      "inputs": {
        "clip_name1": "clip_l.safetensors",
        "clip_name2": "t5xxl_fp16.safetensors",
        "type": "flux"
      }
    },
    "5": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "ae.safetensors"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "Cinematic product shot, studio lighting, 8k, sharp focus",
        "clip": ["4", 0]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, low quality, distorted, watermark, text",
        "clip": ["4", 0]
      }
    },
    "8": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 1024,
        "height": 576,
        "batch_size": 1
      }
    },
    "9": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 25,
        "cfg": 3.5,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": ["3", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["8", 0]
      }
    },
    "10": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["9", 0],
        "vae": ["5", 0]
      }
    },
    "11": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["10", 0],
        "filename_prefix": "vplatform_flux_t2i"
      }
    }
  }
}
